# Copy this file to ".env" and fill in your free-tier API keys.
# All three providers offer free tiers that require no credit card.

# Tavily Search API ............ https://app.tavily.com  (1,000 free credits / month)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Groq (primary LLM) ........... https://console.groq.com  (free, ~14.4K req/day)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini (fallback LLM)  https://aistudio.google.com  (free, 1.5K req/day)
# Optional — if absent, the agent will only use Groq.
GEMINI_API_KEY=

# Ollama (local fallback LLM) ... https://ollama.com  (free, runs on your machine)
# Used only if both Groq and Gemini fail / are unset.
# Make sure `ollama serve` is running and you've pulled the model:
#   ollama pull llama3.1:8b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Tunable knobs (sensible defaults are baked in; uncomment to override) ---
# Lower defaults are chosen to stay under Groq's free-tier 12K tokens-per-minute cap.
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash
# MAX_SEARCH_RESULTS=6
# MAX_PAGES_TO_FETCH=5
# MAX_CONTEXT_TOKENS=2500
# SUMMARIZE_HISTORY_AFTER_TOKENS=3000
